<section class="contact" id="contact">
  <div class="contact__container">
    <h2 class="contact__heading">
      Say hi!
    </h2>
    <form class="contact__form" action="https://api.web3forms.com/submit" method="POST">
      <input type="hidden" name="access_key" value="654913c7-8aac-4c66-91fd-bb8c3fdb10c6">
      <div class="contact__form-grouped">
        <fieldset>
          <label for="name">Name</label>
          <input type="name" id="name" name="name" />
        </fieldset>
        <fieldset>
          <label for="email-address">Email Address</label>
          <input type="email" id="email-address" name="email" />
        </fieldset>
      </div>
      <label for="message">Message</label>
      <textarea id="message" name="message"></textarea>
      <div class="contact__button-container">
        <button type="submit" class="contact__button">Submit</button>
      </div>
    </form>
  </div>
</section>